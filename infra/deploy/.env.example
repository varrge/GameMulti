# Generic self-hosted deployment variables
#
# Auto-generatable values:
# - APP_SECRET / JWT_SECRET / SESSION_SECRET / ENCRYPTION_KEY / CSRF_SECRET
# - INTERNAL_API_TOKEN / WEBHOOK_SIGNING_SECRET
# - DB_PASSWORD / REDIS_PASSWORD / ADMIN_BOOTSTRAP_PASSWORD
# Generate them with:
#   python3 generate_deploy_secrets.py --app-name myapp > .env.generated
#
# Human-supplied values:
# - Public domain / IP
# - SMTP credentials
# - SSH / CI deploy credentials
# - Third-party API credentials

APP_NAME=myapp
APP_ENV=staging
PUBLIC_BASE_URL=https://app.example.com
API_BASE_URL=https://api.example.com
FORUM_BASE_URL=https://forum.example.com
SERVER_PUBLIC_IP=203.0.113.10

APP_SECRET=replace-with-generated-secret
JWT_SECRET=replace-with-generated-secret
SESSION_SECRET=replace-with-generated-secret
ENCRYPTION_KEY=replace-with-generated-secret
CSRF_SECRET=replace-with-generated-secret
INTERNAL_API_TOKEN=replace-with-generated-secret
WEBHOOK_SIGNING_SECRET=replace-with-generated-secret
DB_PASSWORD=replace-with-generated-password
REDIS_PASSWORD=replace-with-generated-password
ADMIN_BOOTSTRAP_PASSWORD=replace-with-generated-password

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=myapp
DB_USER=myapp
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-human-supplied-value
SMTP_PASSWORD=replace-with-human-supplied-value
SMTP_FROM=noreply@example.com

DEPLOY_SSH_HOST=server.example.com
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=deploy
DEPLOY_TARGET_DIR=/srv/myapp

GITHUB_ACTIONS_DEPLOY_KEY=replace-with-human-supplied-value
THIRD_PARTY_API_KEY=replace-with-human-supplied-value
