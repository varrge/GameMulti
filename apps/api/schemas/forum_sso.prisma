generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ForumAccountSyncStatus {
  pending_initial_sync
  active
  syncing
  sync_failed
  disabled
}

enum ForumSsoTicketStatus {
  issued
  consumed
  expired
  cancelled
}

enum ForumSyncJobStatus {
  pending
  processing
  succeeded
  failed
  cancelled
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String         @unique
  status        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  forumAccounts ForumAccount[]
  forumTickets  ForumSsoTicket[]
  forumSyncJobs ForumSyncJob[]
}

model ForumAccount {
  id             String                @id @default(cuid())
  userId         String
  forumProvider  String
  forumUserId    String
  forumUsername  String
  forumEmail     String?
  externalUid    String
  syncStatus     ForumAccountSyncStatus @default(pending_initial_sync)
  mappingSource  String
  lastSyncedAt   DateTime?
  lastLoginAt    DateTime?
  meta           Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  user           User                  @relation(fields: [userId], references: [id])
  ssoTickets      ForumSsoTicket[]
  syncJobs        ForumSyncJob[]

  @@unique([userId, forumProvider])
  @@unique([forumProvider, forumUserId])
  @@unique([forumProvider, externalUid])
  @@index([forumProvider, syncStatus])
}

model ForumSsoTicket {
  id             String              @id @default(cuid())
  userId         String
  forumAccountId String
  forumProvider  String
  ticket         String              @unique
  redirectUrl    String?
  status         ForumSsoTicketStatus @default(issued)
  expiresAt      DateTime
  consumedAt     DateTime?
  requestIp      String?
  requestUserAgent String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user           User                @relation(fields: [userId], references: [id])
  forumAccount   ForumAccount        @relation(fields: [forumAccountId], references: [id])

  @@index([status, expiresAt])
  @@index([forumProvider, status])
}

model ForumSyncJob {
  id               String             @id @default(cuid())
  userId           String
  forumAccountId   String?
  forumProvider    String
  jobType          String
  triggerSource    String
  payload          Json
  status           ForumSyncJobStatus @default(pending)
  dedupeKey        String             @unique
  attemptCount     Int                @default(0)
  maxAttempts      Int                @default(5)
  nextRetryAt      DateTime?
  lastErrorCode    String?
  lastErrorMessage String?
  finishedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user             User               @relation(fields: [userId], references: [id])
  forumAccount     ForumAccount?      @relation(fields: [forumAccountId], references: [id])

  @@index([status, nextRetryAt])
  @@index([forumProvider, jobType, status])
}
