/// 钱包、金币流水、商城订单与封禁审计相关 Prisma 草稿。
/// 目标：一次性补齐 wallets / wallet_transactions / redeem_* / ban_* / audit_logs 基础模型，
/// 方便后续服务实现直接对接。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WalletStatus {
  active
  frozen
  disabled
}

enum WalletTransactionDirection {
  credit
  debit
  freeze
  unfreeze
  adjust
}

enum WalletTransactionStatus {
  pending
  confirmed
  reversed
  failed
}

enum RedeemItemStatus {
  draft
  active
  disabled
  archived
}

enum RedeemOrderStatus {
  pending
  paid
  processing
  delivered
  cancelled
  refunded
  failed
}

enum DeliveryJobStatus {
  pending
  processing
  succeeded
  failed
  cancelled
}

enum BanRecordStatus {
  pending
  active
  lifted
  expired
  sync_failed
}

enum BanActionType {
  ban
  unban
  mute
  kick
  warn
}

enum BanTargetType {
  user
  game_account
  server
  device
  ip
}

enum AuditLogResult {
  success
  rejected
  failed
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  currency      String   @default("coin")
  balance       Int      @default(0)
  frozenBalance Int      @default(0)
  status        WalletStatus @default(active)
  version       Int      @default(1)
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  WalletTransaction[]
  redeemOrders  RedeemOrder[]

  @@index([status, updatedAt])
}

model WalletTransaction {
  id                String   @id @default(cuid())
  walletId          String
  userId            String
  direction         WalletTransactionDirection
  amount            Int
  balanceBefore     Int
  balanceAfter      Int
  frozenBefore      Int      @default(0)
  frozenAfter       Int      @default(0)
  businessType      String
  referenceType     String?
  referenceId       String?
  idempotencyKey    String?
  status            WalletTransactionStatus @default(confirmed)
  operatorId        String?
  operatorType      String?
  ledgerBatchNo     String?
  remark            String?
  metadata          Json?
  createdAt         DateTime @default(now())

  wallet            Wallet   @relation(fields: [walletId], references: [id])

  @@unique([walletId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([businessType, createdAt])
  @@index([referenceType, referenceId])
  @@index([status, createdAt])
}

model RedeemItem {
  id                  String   @id @default(cuid())
  itemCode            String   @unique
  title               String
  description         String?
  itemType            String
  coverImage          String?
  gameCode            String?
  price               Int
  currency            String   @default("coin")
  stock               Int?
  stockReserved       Int      @default(0)
  perUserLimit        Int?
  deliveryType        String   @default("manual")
  deliveryTemplate    Json?
  status              RedeemItemStatus @default(draft)
  sortOrder           Int      @default(100)
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  orderItems          RedeemOrderItem[]
  deliveryJobs        RewardDeliveryJob[]

  @@index([status, sortOrder])
  @@index([gameCode, status])
}

model RedeemOrder {
  id                  String   @id @default(cuid())
  orderNo             String   @unique
  userId              String
  walletId            String
  totalAmount         Int
  currency            String   @default("coin")
  status              RedeemOrderStatus @default(pending)
  deliveryStatus      String   @default("pending")
  note                String?
  cancelReason        String?
  createdAt           DateTime @default(now())
  paidAt              DateTime?
  deliveredAt         DateTime?
  cancelledAt         DateTime?
  updatedAt           DateTime @updatedAt

  wallet              Wallet   @relation(fields: [walletId], references: [id])
  items               RedeemOrderItem[]
  deliveryJobs        RewardDeliveryJob[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([deliveryStatus, createdAt])
}

model RedeemOrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  itemId              String
  quantity            Int
  unitPrice           Int
  totalPrice          Int
  itemSnapshot        Json
  deliverySnapshot    Json?
  deliveryStatus      String   @default("pending")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  order               RedeemOrder @relation(fields: [orderId], references: [id])
  item                RedeemItem  @relation(fields: [itemId], references: [id])
  deliveryJobs        RewardDeliveryJob[]

  @@index([orderId])
  @@index([itemId])
  @@index([deliveryStatus, updatedAt])
}

model RewardDeliveryJob {
  id                  String   @id @default(cuid())
  orderId             String
  orderItemId         String?
  itemId              String
  userId              String
  deliveryChannel     String
  targetType          String
  targetIdentifier    String
  payload             Json
  dedupeKey           String?  @unique
  status              DeliveryJobStatus @default(pending)
  attemptCount        Int      @default(0)
  maxAttempts         Int      @default(5)
  nextRetryAt         DateTime?
  lastError           String?
  lockedAt            DateTime?
  lockedBy            String?
  deliveredAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  order               RedeemOrder     @relation(fields: [orderId], references: [id])
  orderItem           RedeemOrderItem? @relation(fields: [orderItemId], references: [id])
  item                RedeemItem      @relation(fields: [itemId], references: [id])

  @@index([userId, createdAt])
  @@index([status, nextRetryAt])
  @@index([deliveryChannel, status])
}

model BanRecord {
  id                  String   @id @default(cuid())
  banNo               String   @unique
  actionType          BanActionType
  scope               String   @default("global")
  reason              String
  status              BanRecordStatus @default(pending)
  severity            Int      @default(1)
  sourceSystem        String   @default("admin")
  sourceReferenceId   String?
  triggeredByUserId   String?
  approvedByUserId    String?
  effectiveAt         DateTime?
  expiresAt           DateTime?
  liftedAt            DateTime?
  liftedReason        String?
  syncTrace           Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  targets             BanTarget[]
  auditLogs           AuditLog[]

  @@index([status, createdAt])
  @@index([actionType, effectiveAt])
  @@index([sourceSystem, sourceReferenceId])
}

model BanTarget {
  id                  String   @id @default(cuid())
  banRecordId         String
  targetType          BanTargetType
  targetValue         String
  normalizedValue     String?
  gameCode            String?
  serverCode          String?
  metadata            Json?
  createdAt           DateTime @default(now())

  banRecord           BanRecord @relation(fields: [banRecordId], references: [id])

  @@index([banRecordId])
  @@index([targetType, targetValue])
  @@index([gameCode, serverCode])
}

model AuditLog {
  id                  String   @id @default(cuid())
  traceId             String?
  actorId             String?
  actorType           String
  action              String
  resourceType        String
  resourceId          String
  result              AuditLogResult @default(success)
  clientIp            String?
  userAgent           String?
  requestPayload      Json?
  responsePayload     Json?
  diffPayload         Json?
  banRecordId         String?
  remark              String?
  createdAt           DateTime @default(now())

  banRecord           BanRecord? @relation(fields: [banRecordId], references: [id])

  @@index([resourceType, resourceId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([traceId])
  @@index([banRecordId, createdAt])
}
