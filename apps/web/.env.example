# Required at runtime for Gemini-powered features.
GEMINI_API_KEY="your_gemini_api_key"

# Public base URL for this site, used for callbacks or self-references.
APP_URL="http://localhost:3000"

# Public forum entry used by navbar links and post-login redirects.
NEXT_PUBLIC_FORUM_ORIGIN="https://bbs.example.com"
NEXT_PUBLIC_FORUM_ENTRY_PATH="/"

# Optional app runtime settings.
NODE_ENV="production"
PORT="3000"
HOSTNAME="0.0.0.0"
