# Forum SSO configurable integration example
FORUM_SSO_PROVIDER=discourse
FORUM_SSO_BASE_URL=https://forum.example.com
FORUM_SSO_CONSUME_PATH=/session/sso_login
FORUM_SSO_SHARED_SECRET=replace-with-shared-secret
FORUM_SSO_BRIDGE_CALLBACK_URL=https://api.example.com/forum/sso/callback
FORUM_SSO_LOGIN_REDIRECT_URL=https://forum.example.com/
FORUM_SSO_EXTERNAL_UID_FIELD=external_id
FORUM_SSO_MATCH_BY=email
FORUM_SSO_ALLOW_AUTO_CREATE=true
FORUM_SSO_SYNC_PROFILE=true
FORUM_SSO_SYNC_BAN_STATE=true
FORUM_SSO_SYNC_GROUPS=false
FORUM_SSO_TICKET_TTL_SECONDS=300
FORUM_SSO_ALLOWED_REDIRECT_HOSTS=forum.example.com,community.example.com
FORUM_SSO_REQUEST_TIMEOUT_MS=5000
FORUM_SSO_RETRY_MAX_ATTEMPTS=5
FORUM_SSO_RETRY_BASE_DELAY_MS=60000
