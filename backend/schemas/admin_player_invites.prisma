/// Admin 玩家查询与邀请码管理相关的 Prisma 草稿。
/// 目标：补齐后台搜索/列表/详情需要的索引、审计字段与邀请码生成批次模型。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
  banned
}

enum InvitationCodeStatus {
  active
  disabled
  expired
  exhausted
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  email             String   @unique
  passwordHash      String
  status            UserStatus @default(active)
  source            String   @default("invite_register")
  invitedByUserId   String?
  invitationCodeId  String?
  registerIp        String?
  registerUserAgent String?
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  invitedBy         User?    @relation("UserInvites", fields: [invitedByUserId], references: [id])
  invitees          User[]   @relation("UserInvites")
  invitationCode    InvitationCode? @relation(fields: [invitationCodeId], references: [id])
  gameBindings      UserGameBinding[]

  @@index([status, createdAt])
  @@index([lastLoginAt])
}

model InvitationCodeBatch {
  id          String   @id @default(cuid())
  batchNo     String   @unique
  createdBy   String
  ownerUserId String?
  count       Int
  maxUses     Int
  startsAt    DateTime?
  expiresAt   DateTime?
  remark      String?
  createdAt   DateTime @default(now())

  codes       InvitationCode[]

  @@index([createdBy, createdAt])
  @@index([ownerUserId, createdAt])
}

model InvitationCode {
  id          String   @id @default(cuid())
  batchId     String?
  code        String   @unique
  createdBy   String
  ownerUserId String?
  maxUses     Int
  usedCount   Int      @default(0)
  startsAt    DateTime?
  expiresAt   DateTime?
  status      InvitationCodeStatus @default(active)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batch       InvitationCodeBatch? @relation(fields: [batchId], references: [id])
  users       User[]

  @@index([status, createdAt])
  @@index([ownerUserId, status])
  @@index([batchId])
}

model Game {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  GameAccount[]
  servers   GameServer[]
}

model GameServer {
  id         String   @id @default(cuid())
  gameId     String
  serverCode String   @unique
  serverName String
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  game       Game     @relation(fields: [gameId], references: [id])
  userBindings UserGameBinding[]

  @@index([gameId, status])
}

model GameAccount {
  id                   String   @id @default(cuid())
  gameId               String
  platform             String
  gameUserId           String
  normalizedGameUserId String
  displayName          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  game                 Game     @relation(fields: [gameId], references: [id])
  userBindings         UserGameBinding[]

  @@unique([gameId, platform, normalizedGameUserId])
  @@index([gameId, platform, gameUserId])
}

model UserGameBinding {
  id            String   @id @default(cuid())
  userId        String
  gameAccountId String
  serverId      String?
  bindStatus    String
  verifiedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User       @relation(fields: [userId], references: [id])
  gameAccount   GameAccount @relation(fields: [gameAccountId], references: [id])
  server        GameServer? @relation(fields: [serverId], references: [id])

  @@unique([userId, gameAccountId])
  @@index([userId, bindStatus])
  @@index([serverId, bindStatus])
}
